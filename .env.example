# Ussop Configuration
# Copy this file to .env and modify as needed

# App Settings
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8080
SECRET_KEY=change-this-in-production

# Model Paths
ENCODER_PATH=models/resnet18_image_encoder.onnx
DECODER_PATH=models/mobile_sam_mask_decoder.onnx

# Detection Settings
DETECTOR_BACKBONE=mobilenet
CONFIDENCE_THRESHOLD=0.5
MAX_DETECTIONS=20
ONNX_THREADS=0

# Camera Settings
CAMERA_TYPE=mock
CAMERA_INDEX=0
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
CAMERA_FPS=30

# Active Learning
ACTIVE_LEARNING_ENABLED=true
UNCERTAINTY_THRESHOLD_LOW=0.3
UNCERTAINTY_THRESHOLD_HIGH=0.7

# Modbus Integration
MODBUS_ENABLED=false
MODBUS_HOST=0.0.0.0
MODBUS_PORT=502

# MQTT Integration
MQTT_ENABLED=false
MQTT_BROKER=localhost
MQTT_PORT=1883

# Storage
DATABASE_URL=sqlite:///./data/db/ussop.db
IMAGE_RETENTION_DAYS=90
MAX_STORAGE_GB=100

# Redis (optional, for caching — required for multi-worker)
# REDIS_URL=redis://localhost:6379/0
# Docker Compose sets this automatically via x-common-env

# PostgreSQL (production, multi-worker)
# DATABASE_URL=postgresql+psycopg2://ussop:ussop@postgres:5432/ussop
# POSTGRES_PASSWORD=change-in-production

# Grafana
# GRAFANA_PASSWORD=admin

# OPC-UA server (industrial machine connectivity, port 4840)
OPCUA_ENABLED=false
OPCUA_HOST=0.0.0.0
OPCUA_PORT=4840

# OpenVINO acceleration (Intel CPU/GPU/NPU optimization)
OPENVINO_ENABLED=false
OPENVINO_DEVICE=AUTO

# VLM (natural language queries)
# VLM_ENABLED=false
# VLM_BACKEND=local
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
